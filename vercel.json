    "framework": null,
    "buildCommand": "npm install && npm run build",
    "functions": {
        "api/index.php": {
        "runtime": "vercel-php@0.7.1"
        }
    },
    "routes": [
            { "src": "/build/assets/(.*)", "dest": "/public/build/assets/$1" },
            { "src": "/build/(.*)", "dest": "/public/build/$1" },
            { "src": "/images/(.*)", "dest": "/public/images/$1" },
            { "src": "/(.*)\\.(.+)$", "dest": "/public/$1.$2" },
            { "src": "/(.*)", "dest": "/api/index.php" }
        ],
    "env": {
